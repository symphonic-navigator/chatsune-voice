# syntax=docker/dockerfile:1.7
# rocm/pytorch never published a ROCm 6.x + PyTorch 2.5.x combination. This
# tag pairs ROCm 7.2.2 on Ubuntu 24.04 with Python 3.12 and PyTorch 2.7.1,
# satisfies our pyproject `torch>=2.5,<3` constraint, and supports RDNA 3.5
# iGPUs (Strix Halo, gfx1151) natively.
FROM rocm/pytorch:rocm7.2.2_ubuntu24.04_py3.12_pytorch_release_2.7.1

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

# ffmpeg for audio decoding; sox because qwen-tts probes for it internally
# and logs a noisy warning otherwise.
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl ca-certificates ffmpeg sox \
    && rm -rf /var/lib/apt/lists/*

# The rocm/pytorch base image installs its Python and the ROCm-built torch +
# torchaudio into its own virtual environment at /opt/venv. We install OUR
# dependencies into that same venv so pip sees torch 2.7.1+rocm7.2.2 already
# installed (satisfying our `torch>=2.5,<3` constraint in PEP 440) and does
# not replace it with a PyPI CUDA wheel. Creating a second venv here would
# not work — "--system-site-packages" only inherits /usr/lib/python*, not
# another venv's site-packages, so a nested venv would still be torch-less.
ENV PATH="/opt/venv/bin:${PATH}" \
    VIRTUAL_ENV="/opt/venv"

WORKDIR /app
COPY backend/ ./

# Install the project and its dependencies. pip treats torch and torchaudio
# as already-satisfied (the base's 2.7.1+rocm7.2.2 matches any torch>=2.5,<3
# requirement because the local version tag is ignored in version comparison
# when the public version is in range). Nothing CUDA-flavoured is pulled.
RUN pip install --no-cache-dir .

# Try the AMD-distributed onnxruntime-rocm wheel. If this fails (wheel
# unavailable for this ROCm version, or AMD's download host rejects the
# request), the image still boots with onnxruntime-cpu — the Chatterbox
# loader falls back to CPUExecutionProvider at runtime and logs a warning.
# Operators who hit this should set CHATTERBOX_BACKEND=torch in .env.
#
# MUST be the last pip step: onnxruntime is a declared dep in pyproject.toml,
# so it gets installed by `pip install .` above; swapping it earlier would be
# reverted.
ARG ONNXRUNTIME_ROCM_URL=https://repo.radeon.com/rocm/manylinux/rocm-rel-7.2/onnxruntime_rocm-1.19.0-cp312-cp312-manylinux_2_28_x86_64.whl
RUN pip uninstall -y onnxruntime || true \
 && (pip install --no-cache-dir "${ONNXRUNTIME_ROCM_URL}" || \
     (echo "onnxruntime-rocm install failed — image will run ONNX on CPU" \
      && pip install --no-cache-dir onnxruntime))

EXPOSE 8000

# Call uvicorn directly. No `uv run` wrapper, so there is no startup resync
# path that could re-trigger a torch install from PyPI.
CMD ["python", "-m", "uvicorn", "voice.main:app", "--host", "0.0.0.0", "--port", "8000"]
