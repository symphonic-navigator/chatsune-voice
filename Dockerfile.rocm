# syntax=docker/dockerfile:1.7
# rocm/pytorch never published a ROCm 6.x + PyTorch 2.5.x combination. This
# tag pairs ROCm 7.2.2 on Ubuntu 24.04 with Python 3.12 and PyTorch 2.7.1,
# satisfies our pyproject `torch>=2.5,<3` constraint, and supports RDNA 3.5
# iGPUs (Strix Halo, gfx1151) natively.
FROM rocm/pytorch:rocm7.2.2_ubuntu24.04_py3.12_pytorch_release_2.7.1

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

# ffmpeg for audio decoding; sox because qwen-tts probes for it internally
# and logs a noisy warning otherwise.
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl ca-certificates ffmpeg sox \
    && rm -rf /var/lib/apt/lists/*

# Create a venv that inherits the base image's site-packages. The base ships
# a ROCm-built torch AND torchaudio (the CUDA wheels on PyPI would clobber
# both if we ever installed them). With --system-site-packages the venv's
# pip resolver sees torch 2.7.1+rocm7.2 and torchaudio already installed and
# treats any downstream `torch>=x` / `torchaudio>=y` constraint as satisfied
# without downloading replacements from PyPI.
RUN python3 -m venv --system-site-packages /opt/voice-venv
ENV PATH="/opt/voice-venv/bin:${PATH}" \
    VIRTUAL_ENV="/opt/voice-venv"

WORKDIR /app
COPY backend/ ./

# Install the project with all direct dependencies. pip picks up the base
# image's torch / torchaudio as already-satisfied requirements and pulls the
# rest from PyPI in the usual way. We do NOT use uv.lock here because the
# lock was resolved on a CUDA-capable host and pins torch's NVIDIA-specific
# transitive deps (cuda-toolkit, nvidia-cublas, …). The CUDA image keeps
# lockfile reproducibility; the ROCm image trades that for base-image
# torch preservation.
RUN pip install --no-cache-dir .

EXPOSE 8000

# Call uvicorn directly. No `uv run` wrapper, so there is no startup resync
# path that could re-trigger a torch install from PyPI.
CMD ["python", "-m", "uvicorn", "voice.main:app", "--host", "0.0.0.0", "--port", "8000"]
