# ===== Hardware profile =====
# Set one of: cuda (NVIDIA + nvidia-container-toolkit), rocm (AMD incl. Strix Halo).
# You MUST set this; otherwise `docker compose up` will not start any service.
COMPOSE_PROFILES=cuda

# Image tag. Published by GitHub Actions to both :cuda-latest and :rocm-latest.
# APP_IMAGE=ghcr.io/symphonic-navigator/chatsune-voice:cuda-latest

# ===== Paths =====
MODEL_CACHE_DIR=./models
APP_PORT=8000

# ===== Model selection (defaults are usually correct) =====
# STT_MODEL=h2oai/faster-whisper-large-v3-turbo
# TTS_CUSTOM_VOICE_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
# TTS_VOICE_DESIGN_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-VoiceDesign

# ===== Runtime behaviour =====
# Subset allowed, e.g. "custom_voice,clone" for smaller GPUs that cannot
# host VoiceDesign in addition.
TTS_ENABLED_MODES=custom_voice,voice_design,clone

# keep_loaded: all enabled TTS models resident simultaneously (recommended >= 24 GB VRAM).
# swap:        one TTS model at a time; mode switches are serialised via an asyncio lock.
TTS_VRAM_POLICY=keep_loaded

# PyTorch attention: sdpa | flash_attention_2 | eager. flash_attention_2 needs --build-arg
# INSTALL_FLASH_ATTN=1 at image build time and is CUDA-only.
TTS_ATTENTION_IMPL=sdpa

# ===== Chatterbox (voice cloning mode) =====
# Model ID. The ONNX-community Q4 port is the default; on hosts where
# onnxruntime-rocm is unavailable or the ONNX inference pipeline is not
# yet implemented (see "Cloning mode" in the README), operators can set
# CHATTERBOX_BACKEND=torch — but note that requires installing the
# chatterbox-tts pip package manually (it conflicts with qwen-tts on
# transformers version and is not a declared dependency).
CHATTERBOX_MODEL=onnx-community/chatterbox-multilingual-ONNX

# Inference backend. "onnx" loads the 4 ONNX sessions with
# CUDAExecutionProvider / ROCMExecutionProvider as available. "torch" is
# an optional bring-your-own fallback (chatterbox-tts pip package must be
# installed alongside by the operator).
CHATTERBOX_BACKEND=onnx

# Device string passed to the backend. On ROCm, "cuda" resolves via HIP.
CHATTERBOX_DEVICE=cuda

# Reference-audio upload limits.
CHATTERBOX_MAX_REFERENCE_BYTES=10485760
CHATTERBOX_MAX_REFERENCE_SECONDS=30

# CTranslate2 compute type for the Whisper STT model (passed to faster-whisper).
# Allowed: auto | int8 | int8_float16 | int8_bfloat16 | int8_float32 |
#          int16 | float16 | bfloat16 | float32
#
# "auto" picks the best supported type for the detected device:
#   - On CUDA with Tensor cores: int8_float16 (optimal weight-bandwidth +
#     fp16 activations, <0.5% WER degradation vs. plain float16).
#   - On CPU: int8 if AVX-VNNI is available, else int8_float32.
#
# CPUs cannot use int8_float16 or float16 directly (fp16 compute is a GPU-
# only capability). Do not hard-code one of those here if your STT_DEVICE
# resolves to CPU — you will get a ValueError at load time.
STT_COMPUTE_TYPE=auto

# Load models at start-up (true) or lazily on first request (false).
PRELOAD_AT_STARTUP=true

# ===== GPU devices =====
# STT (CTranslate2 / faster-whisper) and TTS (PyTorch / qwen-tts) reach the
# GPU through different libraries with different compatibility stories:
#
# STT_DEVICE options: auto | cuda | cpu
#   - "auto" picks cuda if an NVIDIA driver is present, else cpu. Safe default.
#   - "cuda" requires an NVIDIA driver + nvidia-container-toolkit. CTranslate2's
#     PyPI wheel is CUDA-only: there is no ROCm build, so ROCm hosts MUST use
#     "auto" (→ cpu) or "cpu" explicitly. Whisper Turbo runs near real-time on
#     a modern 16-core CPU with int8 quantisation, so this is not painful.
# TTS_DEVICE options: cuda | cpu
#   - "cuda" works on both NVIDIA and ROCm hosts (ROCm-PyTorch exposes the CUDA
#     API via HIP). "cpu" is technically possible for qwen-tts but far too slow
#     in practice — use a GPU.
STT_DEVICE=auto
TTS_DEVICE=cuda

# ===== ROCm-specific (only used when COMPOSE_PROFILES=rocm) =====
# Strix Halo iGPU (gfx1151) typically "11.5.1"; some discrete RDNA3 cards do not need this.
HSA_OVERRIDE_GFX_VERSION=11.5.1

# ===== Hugging Face authentication (optional) =====
# The model repos we use (h2oai/..., Qwen/...) are public and do not require a
# token. Set HF_TOKEN here only if you are swapping in a gated model or want to
# raise the download rate limit for your account. The token is forwarded into
# the container as HF_TOKEN, which both huggingface_hub and the TTS/STT
# libraries pick up automatically.
# HF_TOKEN=hf_your_token_here

# ===== Miscellaneous =====
LOG_LEVEL=info
STT_MAX_AUDIO_BYTES=26214400
